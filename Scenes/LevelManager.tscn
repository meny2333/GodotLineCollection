[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://Scripts/LevelManager.gd" id="1"]

[node name="LevelManager" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "UGC 关卡合集"
horizontal_alignment = 1

[node name="InfoLabel" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "选择一个关卡开始游戏"
horizontal_alignment = 1

[node name="LevelList" type="ItemList" parent="VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="ButtonContainer" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="PlayButton" type="Button" parent="VBoxContainer/ButtonContainer"]
layout_mode = 2
size_flags_horizontal = 3
text = "开始游戏"

[node name="LoadPckButton" type="Button" parent="VBoxContainer/ButtonContainer"]
layout_mode = 2
text = "加载PCK"

[node name="RefreshButton" type="Button" parent="VBoxContainer/ButtonContainer"]
layout_mode = 2
text = "刷新列表"

[connection signal="item_selected" from="VBoxContainer/LevelList" to="." method="_on_level_list_item_selected"]
[connection signal="pressed" from="VBoxContainer/ButtonContainer/PlayButton" to="." method="_on_play_button_pressed"]
[connection signal="pressed" from="VBoxContainer/ButtonContainer/LoadPckButton" to="." method="_on_load_pck_button_pressed"]
[connection signal="pressed" from="VBoxContainer/ButtonContainer/RefreshButton" to="." method="_on_refresh_button_pressed"]
